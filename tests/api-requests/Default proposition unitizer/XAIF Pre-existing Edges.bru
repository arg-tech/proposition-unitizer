meta {
  name: XAIF Pre-existing Edges
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/propositionUnitizer-01
  body: multipartForm
  auth: inherit
}

headers {
  Content-Type: multipart/form-data
}

body:multipart-form {
  file: @file(test-inputs/xaif_pre_existing_edges.json)
}

tests {
  const expectedData =
  {
    "AIF": {
      "descriptorfulfillments": null,
      "edges": [
        {
          "edgeID": 10,
          "fromID": 0,
          "toID": 1
        },
        {
          "edgeID": 11,
          "fromID": 0,
          "toID": 3
        },
        {
          "edgeID": 12,
          "fromID": 3,
          "toID": 2
        },
        {
          "edgeID": 13,
          "fromID": 1,
          "toID": 5
        },
        {
          "edgeID": 14,
          "fromID": 5,
          "toID": 4
        }
      ],
      "locutions": [
        {
          "nodeID": 0,
          "personID": 0
        },
        {
          "nodeID": 1,
          "personID": 1
        }
      ],
      "nodes": [
        {
          "nodeID": 0,
          "text": "Education spending should increase.",
          "type": "L"
        },
        {
          "nodeID": 1,
          "text": "Healthcare is more urgent.",
          "type": "L"
        },
        {
          "nodeID": 2,
          "text": "Education spending should increase.",
          "type": "I"
        },
        {
          "nodeID": 3,
          "text": "Default Illocuting",
          "type": "YA"
        },
        {
          "nodeID": 4,
          "text": "Healthcare is more urgent.",
          "type": "I"
        },
        {
          "nodeID": 5,
          "text": "Default Illocuting",
          "type": "YA"
        }
      ],
      "participants": [
        {
          "firstname": "Speaker",
          "participantID": 0,
          "surname": "1"
        },
        {
          "firstname": "Speaker",
          "participantID": 1,
          "surname": "2"
        }
      ],
      "schemefulfillments": null
    },
    "dialog": true,
    "ova": [],
    "text": {
      "txt": " Speaker 1 <span class=\"highlighted\" id=\"0\">Education spending should increase.</span>.<br><br> Speaker 2 <span class=\"highlighted\" id=\"1\">Healthcare is more urgent.</span>.<br><br>"
    }
  };

  const maxTimeToReturnInMilliseconds = 300;

  test("Response should match expected value", function () {
    const receivedData = res.getBody();
    expect(receivedData).to.deep.equal(expectedData);
  });

  test("New edge IDs should continue from existing max (10)", function () {
    const edges = res.getBody().AIF.edges;
    const newEdges = edges.filter(e => e.edgeID > 10);
    const newEdgeIDs = newEdges.map(e => e.edgeID).sort();
    expect(newEdgeIDs).to.deep.equal([11, 12, 13, 14]);
  });

  test("Pre-existing edge should be preserved", function () {
    const edges = res.getBody().AIF.edges;
    const original = edges.find(e => e.edgeID === 10);
    expect(original).to.deep.equal({ "edgeID": 10, "fromID": 0, "toID": 1 });
  });

  test(`Response time should be faster than ${maxTimeToReturnInMilliseconds} milliseconds`, function () {
    expect(res.responseTime).to.be.below(maxTimeToReturnInMilliseconds);
  });
}
